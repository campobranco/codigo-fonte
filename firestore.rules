// ATENÇÃO: REGRA DE EDIÇÃO - Este arquivo NÃO deve ser editado sem antes discutir a alteração.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper functions ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      return request.auth != null && 
             request.auth.token.email == 'campobrancojw@gmail.com';
    }

    function getAuthCongregationId() {
      return request.auth.token.get('congregationId', request.auth.token.get('congregation_id', '')) != '' 
        ? request.auth.token.get('congregationId', request.auth.token.get('congregation_id', ''))
        : (exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
            ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('congregationId', get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('congregation_id', '')) 
            : '');
    }

    function getAuthRole() {
      return request.auth.token.get('role', '') != ''
        ? request.auth.token.get('role', '')
        : (exists(/databases/$(database)/documents/users/$(request.auth.uid))
            ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'PUBLICADOR')
            : 'PUBLICADOR');
    }

    function isAdmin() {
      return isAuthenticated() && 
             (getAuthRole() == 'ADMIN' || isMasterAdmin());
    }

    function isElder() {
      return isAuthenticated() && 
             (getAuthRole() == 'ANCIAO' || isAdmin());
    }
    
    function isServant() {
      return isAuthenticated() && (
             isElder() || 
             getAuthRole() == 'SERVO' || 
             'SERVO' in request.auth.token.get('roles', []) ||
             'ANCIAO' in request.auth.token.get('roles', [])
      );
    }

    function isPublisher() {
      return isAuthenticated() && (
             isServant() ||
             getAuthRole() == 'PUBLICADOR' ||
             'PUBLICADOR' in request.auth.token.get('roles', [])
      );
    }

    // Funções "Lite" para uso dentro da coleção users (evita recursão)
    function isMasterLite() {
       return request.auth != null && request.auth.token.email == 'campobrancojw@gmail.com';
    }
    function isAdminToken() {
       return request.auth != null && (request.auth.token.role == 'ADMIN' || isMasterLite());
    }
    function isElderToken() {
       return request.auth != null && (isAdminToken() || request.auth.token.role == 'ANCIAO');
    }
    function isServantToken() {
       return request.auth != null && (isElderToken() || request.auth.token.role == 'SERVO' || 'SERVO' in request.auth.token.get('roles', []));
    }
    
    // --- Lógica de Isolamento ---

    // Verifica se os dados solicitados pertencem à congregação do usuário
    function belongsToUserCongregation(docData) {
      return isAuthenticated() && (
        isAdmin() || (
          docData.get('congregationId', docData.get('congregation_id', '')) == getAuthCongregationId() && 
          getAuthCongregationId() != ""
        )
      );
    }

    // Garante que o congregationId não possa ser alterado durante uma atualização
    function congregationIdIsImmutable() {
       return resource.data.get('congregationId', resource.data.get('congregation_id', '')) == 
              request.resource.data.get('congregationId', request.resource.data.get('congregation_id', ''));
    }



    // --- Collection Rules ---

    // 1. Congregations (Congregações)
    match /congregations/{congregationId} {
      allow read: if isAuthenticated(); // Permite leitura para qualquer usuário autenticado
      allow create: if isAuthenticated() && isAdmin();
      // Permite atualização se for da própria congregação e for Servo ou Ancião
      allow update: if isAuthenticated() && (isAdmin() || (isServant() && (congregationId == getAuthCongregationId())) );
      allow delete: if isAuthenticated() && isAdmin();
    }

    // 2. Usuários (Acesso Estrito e Perfil)
    match /users/{userId} {
      // LEITURA PRÓPRIA: O usuário pode SEMPRE ler seu próprio perfil (get)
      allow get: if isAuthenticated() && request.auth.uid == userId;

      // ACESSO MASTER
      allow read, write: if isMasterLite();

      // Listagem: Apenas quem tem congregação ou Admin
      allow list: if isAuthenticated() && (isAdminToken() || request.auth.token.get('congregationId', '') != '');
      
      // Atualização: Próprio usuário (campos limitados) ou Ancião da mesma congregação
      allow update: if isAuthenticated() && (
        isAdminToken() ||
        (request.auth.uid == userId && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)) || 
        (isElderToken() && resource.data.get('congregationId', '') == request.auth.token.get('congregationId', ''))
      );
      
      allow create, delete: if isAdminToken();
    }

    // 3. Cities
    match /cities/{cityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isAdmin() || (isServant() && belongsToUserCongregation(request.resource.data)));
      allow update: if isAuthenticated() && (isAdmin() || (isServant() && belongsToUserCongregation(resource.data) && congregationIdIsImmutable()));
      allow delete: if isAuthenticated() && (isAdmin() || (isServant() && belongsToUserCongregation(resource.data)));
    }

    // 4. Coleções Principais (Territórios, Endereços)
    match /territories/{id} {
        allow read: if isAuthenticated() && belongsToUserCongregation(resource.data);
        allow create: if isAuthenticated() && (isAdmin() || (isServant() && belongsToUserCongregation(request.resource.data)));
        // Estrito: Deve pertencer à congregação e não pode mudar o congId
        allow update: if isAuthenticated() && (isAdmin() || (isServant() && belongsToUserCongregation(resource.data) && belongsToUserCongregation(request.resource.data) && congregationIdIsImmutable()));
        allow delete: if isAuthenticated() && (isAdmin() || (isServant() && belongsToUserCongregation(resource.data)));
    }

    match /addresses/{id} {
        // LEITURA: Permite qualquer usuário autenticado da mesma congregação
        allow read: if isAuthenticated() && belongsToUserCongregation(resource.data);
        
        // CRIAÇÃO: Deve pertencer à congregação do usuário
        allow create: if isAuthenticated() && belongsToUserCongregation(request.resource.data);
        
        // ATUALIZAÇÃO: Apenas Servos e Anciões podem atualizar endereços (incluindo reordenação)
        allow update: if isAuthenticated() && (
            isMasterAdmin() ||
            (isServant() && belongsToUserCongregation(resource.data) && congregationIdIsImmutable())
        );
        
        // EXCLUSÃO: Servos e Anciões (ou Admin)
        allow delete: if isAuthenticated() && (
            isAdmin() ||
            (isServant() && belongsToUserCongregation(resource.data))
        );
    }

    // 5. Visitas (Subcoleção)
    match /{document=**}/visits/{id} {
        // LEITURA ESTRITA: Pertence à congregação OU é compartilhada publicamente
        allow read: if (isAuthenticated() && (
            isAdmin() || 
            (isPublisher() && belongsToUserCongregation(resource.data))
        )) ||
        (resource.data.shareId != null && exists(/databases/$(database)/documents/shared_lists/$(resource.data.shareId)));

        allow create: if isAuthenticated() && (
            isAdmin() || 
            (isPublisher() && belongsToUserCongregation(request.resource.data))
        );

        allow update: if isAuthenticated() && (
            isAdmin() || 
            (isPublisher() && belongsToUserCongregation(resource.data) && congregationIdIsImmutable())
        );

        allow delete: if isAuthenticated() && (
            isAdmin() || 
            (isServant() && belongsToUserCongregation(resource.data))
        );
    }

    // 6. Listas Compartilhadas (Leitura Pública, Escrita Autenticada)
    match /shared_lists/{id} {
        allow get: if true; // Público para compartilhamento
        allow list: if isAuthenticated() && (
            isAdmin() || 
            isPublisher() && (
                resource.data.get('assignedTo', '') == request.auth.uid || 
                resource.data.get('assigned_to', '') == request.auth.uid ||
                belongsToUserCongregation(resource.data)
            )
        );
        match /items/{itemId} { 
            // Leitura pública para compartilhamento (get e list)
            allow get, list: if true;
            
            // CRIAÇÃO: Apenas autenticados na própria congregação
            allow create: if isAuthenticated() && belongsToUserCongregation(request.resource.data);
            
            // ATUALIZAÇÃO/EXCLUSÃO: Apenas quem tem acesso à congregação
            allow update, delete: if isAuthenticated() && (isAdmin() || belongsToUserCongregation(resource.data));
        }
        match /territory_addresses/{addrId} { 
            // Leitura pública para compartilhamento (get e list)
            allow get, list: if true;
            
            // CRIAÇÃO: Apenas autenticados na própria congregação
            allow create: if isAuthenticated() && belongsToUserCongregation(request.resource.data);
            
            // ATUALIZAÇÃO/EXCLUSÃO: Apenas quem tem acesso à congregação
            allow update, delete: if isAuthenticated() && (isAdmin() || belongsToUserCongregation(resource.data));
        }
        
        // CRIAÇÃO: Apenas autenticados na própria congregação
        allow create: if isAuthenticated() && (isAdmin() || belongsToUserCongregation(request.resource.data));
        
        // ATUALIZAÇÃO/EXCLUSÃO: Apenas quem tem acesso à congregação
        allow update, delete: if isAuthenticated() && (
            isAdmin() || 
            isPublisher() && belongsToUserCongregation(resource.data)
        );
        
        match /results/{resultId} {
            // Recursos públicos para a visualização compartilhada
            allow read: if true;
            
            // ESCRITA PÚBLICA: Aceitável porque:
            // 1. Os dados já são públicos (listas compartilhadas)
            // 2. O escopo é limitado (apenas resultados para esta lista específica)
            // 3. O tamanho é controlado (< 10 campos)
            // 4. Nenhum dado sensível é armazenado
            allow write: if true && request.resource.data.size() < 10; 
        }
    }

    // 7. Pontos de Testemunho
    match /witnessing_points/{id} {
        allow read: if isAuthenticated() && (isAdmin() || belongsToUserCongregation(resource.data));
        allow create: if isAuthenticated() && (isAdmin() || (isServant() && belongsToUserCongregation(request.resource.data)));
        allow update: if isAuthenticated() && (isAdmin() || (isServant() && belongsToUserCongregation(resource.data) && congregationIdIsImmutable()));
        allow delete: if isAuthenticated() && (isAdmin() || (isServant() && belongsToUserCongregation(resource.data)));
    }

    // 8. Modelos e Relatórios
    match /notification_templates/{id} {
        // Leitura restrita à própria congregação se o campo existir, caso contrário global? 
        // Assumindo modelos globais por enquanto, mas impedindo escritas.
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && isAdmin();
    }

    // REGRAS DE RELATÓRIOS DE BUGS (Bug Reports)
    match /bug_reports/{reportId} {
        allow create: if isAuthenticated()
          && (request.resource.data.userId == request.auth.uid || request.resource.data.user_id == request.auth.uid);
          
        allow read: if isAdmin();
        allow update: if isAdmin();
        allow delete: if false;
    }

    match /error_reports/{reportId} {
        allow create: if isAuthenticated()
          && (request.resource.data.userId == request.auth.uid || request.resource.data.user_id == request.auth.uid);
          
        allow read: if isAdmin();
        allow update: if isAdmin();
        allow delete: if false;
    }
    
    // Negação Padrão para Tudo (Explícito para boas práticas)
  }
}
