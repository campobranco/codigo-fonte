{
  "hosting": [
    {
      "site": "campo-branco",
      "source": "."
    },
    {
      "site": "campobranco",
      "source": "."
    }
  ],
  "firestore": [
    {
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json",
      "database": "(default)"
    },
    {
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json",
      "database": "campobrancodev"
    }
  ],
  "apphosting": {
    "backendId": "campo-branco",
    "rootDir": "/",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "functions"
    ],
    "alwaysDeployFromSource": true
  },
  "storage": {
    "rules": "storage.rules"
  }
}